#!/usr/bin/env bash
set -euo pipefail

# LightDM typically launches X11 sessions from /usr/share/xsessions.
# Default to X11 for compatibility, but allow override.
BACKEND="${SNOWDESK_BACKEND:-x11}"

snowdesk-panel &
PANEL_PID=$!

snowdesk-dock &
DOCK_PID=$!

cleanup() {
  kill "$PANEL_PID" "$DOCK_PID" 2>/dev/null || true
}
trap cleanup EXIT

if [[ "$BACKEND" == "wayland" ]]; then
  exec snowdesk-wm --wayland
else
  exec snowdesk-wm --x11
fi
